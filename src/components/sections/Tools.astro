---
import Container from '../layout/Container.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import tools from '../../data/tools.json';
import { useTranslations } from '../../i18n/translations';
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section class="animate-in delay-600">
  <Container>
    <SectionLabel>{t.toolsHeading}</SectionLabel>
    <div
      class="relative overflow-hidden"
      style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);"
    >
      <div class="flex gap-6 animate-marquee hover:[animation-play-state:paused] pb-10 pt-2 w-max">
        {[...tools, ...tools].map((tool) => (
          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative"
          >
            <img
              src={tool.logo}
              alt={tool.name}
              width="52"
              height="52"
              class="size-13 object-contain"
              loading="lazy"
            />
            <!-- Tooltip -->
            <span class="pointer-events-none absolute -bottom-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-md bg-overlay px-2 py-1 text-xs font-medium text-dim opacity-0 transition-opacity group-hover:opacity-100 z-10">
              {tool.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </Container>
</section>
