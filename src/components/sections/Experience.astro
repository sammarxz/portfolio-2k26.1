---
import Container from "../layout/Container.astro";
import Button from "../ui/Button.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import { Icon } from "astro-icon/components";
import { useTranslations } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";
import type { Experience } from "../../types/data";

import experiencesEn from "../../data/experience.json";
import experiencesPt from "../../i18n/data/experience.pt.json";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const experiences: Experience[] = lang === "pt" ? experiencesPt : experiencesEn;
---

<section class="animate-in delay-650">
  <Container>
    <SectionLabel>{t.experienceHeading}</SectionLabel>
    <p class="mb-6 leading-relaxed text-dim">
      {t.experienceIntro}
    </p>

    <div class="flex flex-col mb-6">
      {
        experiences.map((exp) => (
          <div class="flex flex-col gap-1 py-4 sm:grid sm:grid-cols-[120px_1fr] sm:gap-4">
            <span class="font-mono text-xs uppercase tracking-wider text-mute leading-tight sm:pt-1">
              {exp.period}
            </span>
            <div>
              <p class="mb-1.5 text-base text-ink flex items-center gap-1.5 flex-wrap">
                {exp.role}
                {exp.company}
              </p>
              <p class="text-base leading-relaxed text-dim">
                {exp.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="flex items-center flex-wrap gap-4">
      <Button
        href="/SamMarxz_Resume_2k26.pdf"
        variant="secondary"
        class="w-full sm:w-auto items-center justify-center"
      >
        <Icon
          name="lucide:download"
          width={14}
          height={14}
          class="mr-2"
          aria-hidden="true"
        />
        {t.downloadResume}
      </Button>
      <p
        class="text-sm text-mute italic text-center w-full sm:w-auto sm:text-left"
      >
        SamMarxz_Resume_2k26.pdf (53,8 kb)
      </p>
    </div>
  </Container>
</section>
